generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("WAREHOUSE_AUDIT_DB_URL")
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String   // admin | auditor
  createdAt DateTime @default(now()) @map("created_at")
  isActive  Boolean  @default(true) @map("is_active")

  @@map("users")
}

model InventoryUpload {
  id         String      @id @default(cuid())
  filename   String
  uploadedBy String      @map("uploaded_by")
  createdAt  DateTime    @default(now()) @map("created_at")
  devices    Inventory[]

  @@map("inventory_uploads")
}

model Inventory {
  id           String          @id @default(cuid())
  uploadId     String          @map("upload_id")
  upload       InventoryUpload @relation(fields: [uploadId], references: [id])
  locationCode String          @map("location_code")
  itemNo       String?         @map("item_no")
  no2          String?
  description  String?
  inventory    String?
  binCode      String          @map("bin_code")
  zoneCode     String?         @map("zone_code")
  serialNo     String?         @map("serial_no")
  macId        String?         @map("mac_id")
  deviceId     String?         @map("device_id")
  createdAt    DateTime        @default(now()) @map("created_at")

  @@map("inventory")
}

model Assignment {
  id         String   @id @default(cuid())
  uploadId   String   @map("upload_id")
  warehouse  String
  binCode    String   @map("bin_code")
  assignedTo String   @map("assigned_to")
  assignedBy String   @map("assigned_by")
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("assignments")
}

model AuditSession {
  id           String          @id @default(cuid())
  auditorEmail String          @map("auditor_email")
  warehouse    String
  startTime    DateTime        @default(now()) @map("start_time")
  endTime      DateTime?       @map("end_time")
  isReaudit    Boolean         @default(false) @map("is_reaudit")
  createdAt    DateTime        @default(now()) @map("created_at")
  scans        ScannedDevice[]

  @@map("audit_sessions")
}

model ScannedDevice {
  id              String       @id @default(cuid())
  sessionId       String       @map("session_id")
  session         AuditSession @relation(fields: [sessionId], references: [id])
  binCode         String       @map("bin_code")
  warehouse       String
  rawInput        String       @map("raw_input")
  extractedSerial String?      @map("extracted_serial")
  matched         Boolean      @default(false)
  deviceType      String?      @map("device_type")
  serialNo        String?      @map("serial_no")
  macId           String?      @map("mac_id")
  deviceId        String?      @map("device_id")
  scanType        String       @map("scan_type")
  scannedAt       DateTime     @default(now()) @map("scanned_at")

  @@map("scanned_devices")
}

model Correction {
  id          String   @id @default(cuid())
  warehouse   String
  binCode     String   @map("bin_code")
  remark      String
  correctedBy String   @map("corrected_by")
  correctedAt DateTime @default(now()) @map("corrected_at")

  @@map("corrections")
}

model ReauditAssignment {
  id         String   @id @default(cuid())
  warehouse  String
  binCode    String   @map("bin_code")
  assignedTo String   @map("assigned_to")
  assignedBy String   @map("assigned_by")
  createdAt  DateTime @default(now()) @map("created_at")
  completed  Boolean  @default(false)

  @@map("reaudit_assignments")
}

model OtpToken {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  @@map("otp_tokens")
}
